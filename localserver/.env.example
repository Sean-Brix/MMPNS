# URL of the Firebase Cloud Functions API
# Production:
CLOUD_URL=https://us-central1-mmpns-9bdde.cloudfunctions.net/api
# Local Firebase emulator (use this when running 'firebase emulators:start'):
# CLOUD_URL=http://127.0.0.1:5001/mmpns-9bdde/us-central1/api

# Port this local server listens on
LOCAL_SERVER_PORT=3001

# Credentials for the dedicated local-server admin account on the cloud
ADMIN_USER=localserver
ADMIN_PASS=your_admin_password_here

# Sync interval in milliseconds (default: 1 hour)
SYNC_INTERVAL_MS=3600000
